#include <Wire.h>
#include <Adafruit_MPU6050.h>
#include <Adafruit_Sensor.h>
#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <UniversalTelegramBot.h>
#include <ArduinoJson.h>
#include <TinyGPS++.h>

// ==========================================
// 1. ตั้งค่า Wi-Fi และ Telegram
// ==========================================
const char* ssid = "realme 8 5G";
const char* password = "11111111";
const char* botToken = "8349275567:AAEF4E7szsTl6p3He8q-Q7aqWV5KloFYFVQ";
const char* chatID = "8044222650";

WiFiClientSecure client;
UniversalTelegramBot bot(botToken, client);

// ==========================================
// 2. กำหนดขาอุปกรณ์
// ==========================================
const int pingPin = 32;  // Trig
const int inPin = 33;    // Echo
const int buzzer = 27;   // Buzzer
const int motor = 23;    // Motor
#define GPS_RX_PIN 16    
#define GPS_TX_PIN 17    

// ==========================================
// 3. ตัวแปรระบบ
// ==========================================
Adafruit_MPU6050 mpu;
TinyGPSPlus gps;
HardwareSerial gpsSerial(2);

// ตั้งค่าระยะการแจ้งเตือน
const int DIST_DANGER = 30;   
const int DIST_WARNING = 60;  

// *** แก้ไขจุดนี้: เพิ่มค่าเกณฑ์การล้มให้สูงขึ้น ***
// ค่าเดิม 15.0 (ไวไป) -> แก้เป็น 25.0 (ต้องกระแทกแรงถึงจะทำงาน)
const float FALL_THRESHOLD = 25.0; 

unsigned long lastFallTime = 0;       
unsigned long lastObstacleTime = 0;   
unsigned long lastPrintTime = 0; 
int lastValidCm = 0; 

// ==========================================
// 4. SETUP
// ==========================================
void setup() {
  Serial.begin(115200);
  gpsSerial.begin(9600, SERIAL_8N1, GPS_RX_PIN, GPS_TX_PIN);

  pinMode(pingPin, OUTPUT);
  pinMode(inPin, INPUT); 
  pinMode(buzzer, OUTPUT);
  pinMode(motor, OUTPUT);

  digitalWrite(buzzer, HIGH); 
  digitalWrite(motor, LOW);

  Serial.print("Connecting WiFi");
  WiFi.begin(ssid, password);
  client.setInsecure();
  
  int timeout = 0;
  while (WiFi.status() != WL_CONNECTED && timeout < 20) {
    delay(500); Serial.print(".");
    timeout++;
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✅ Online!");
    bot.sendMessage(chatID, "Smart Cane Ready! (Less Sensitive)", "");
  } else {
    Serial.println("\n⚠️ Offline Mode");
  }

  if (!mpu.begin()) {
    Serial.println("❌ MPU6050 Error!");
    while (1) delay(10);
  }
  mpu.setAccelerometerRange(MPU6050_RANGE_8_G);
  
  Serial.println("✅ System Ready! Go outside for GPS.");
  beep(100); 
}

// ==========================================
// 5. LOOP
// ==========================================
void loop() {
  // 1. อ่าน GPS
  while (gpsSerial.available() > 0) gps.encode(gpsSerial.read());

  // 2. วัดระยะทาง (Filter ค่า 0)
  long duration, cm;
  
  digitalWrite(pingPin, LOW);
  delayMicroseconds(2);
  digitalWrite(pingPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(pingPin, LOW);
  
  duration = pulseIn(inPin, HIGH, 25000); 
  
  if (duration == 0) {
    cm = lastValidCm; 
  } else {
    long tempCm = duration * 0.034 / 2;
    if (tempCm > 400) {
       cm = lastValidCm;
    } else {
       cm = tempCm;
       lastValidCm = cm; 
    }
  }

  // แสดงผล
  if (millis() - lastPrintTime > 500) {
    Serial.print("Distance: ");
    Serial.print(cm);
    Serial.print(" cm | GPS Fix: ");
    if (gps.location.isValid()) {
      Serial.print("✅ YES (");
      Serial.print(gps.location.lat(), 6);
      Serial.println(")");
    } else {
      Serial.println("❌ NO (Waiting...)");
    }
    lastPrintTime = millis();
  }

  // 3. Logic เสียงเตือนระยะ
  int beepInterval = 0; 
  if (cm > 2) { 
    if (cm < DIST_DANGER) beepInterval = 100;      
    else if (cm < DIST_WARNING) beepInterval = 400; 
  }

  if (beepInterval > 0) {
    if (millis() - lastObstacleTime > beepInterval) {
      beep(50); 
      lastObstacleTime = millis();
    }
  }

  // 4. Logic แจ้งเตือนล้ม (ต้องกระแทกแรงขึ้น)
  sensors_event_t a, g, temp;
  mpu.getEvent(&a, &g, &temp);
  float totalAccel = sqrt(pow(a.acceleration.x, 2) + 
                          pow(a.acceleration.y, 2) + 
                          pow(a.acceleration.z, 2));

  // [DEBUG] เอาไว้ดูค่าแรงเหวี่ยง จะได้ปรับเลขถูก
  // Serial.print("Accel: "); Serial.println(totalAccel); 

  if (totalAccel > FALL_THRESHOLD && (millis() - lastFallTime > 10000)) {
    Serial.println("!!! FALL DETECTED !!!");
    lastFallTime = millis();
    
    digitalWrite(motor, HIGH);
    for(int i=0; i<5; i++) { 
      beep(200);
      delay(200);
    }
    digitalWrite(motor, LOW);

    sendEmergencyMessage();
  }
}

// ==========================================
// 6. Helper Functions
// ==========================================
void beep(int ms) {
  digitalWrite(buzzer, LOW);  
  delay(ms);
  digitalWrite(buzzer, HIGH); 
}

void sendEmergencyMessage() {
  if (WiFi.status() == WL_CONNECTED) {
    String msg = "🚨 ช่วยด้วย! ผู้ใช้ไม้เท้าล้มลง! 🚨\n";
    
    unsigned long startWait = millis();
    while (millis() - startWait < 1000) {
      while (gpsSerial.available() > 0) gps.encode(gpsSerial.read());
    }

    if (gps.location.isValid()) {
      msg += "📍 พิกัด: http://maps.google.com/maps?q=";
      msg += String(gps.location.lat(), 6);
      msg += ",";
      msg += String(gps.location.lng(), 6);
    } else {
      msg += "⚠️ GPS กำลังค้นหาสัญญาณ...";
    }

    bot.sendMessage(chatID, msg, "");
  }
}
